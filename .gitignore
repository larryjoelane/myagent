# dependencies
node_modules/
.pnp/
.pnp.*

# build output
dist/
out/
build/
*.tsbuildinfo
renderer/dist/

# generated by the agent
project-output/

# on-demand UI screenshots — regenerate with `npm run shots`
docs/screenshots/

# per-launch session logs + generated artifacts. Track committed,
# user-authored config (hooks, skills); ignore the rest of .myagent/.
.myagent/*
!.myagent/hooks/
!.myagent/skills/

# logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# env / secrets
.env
.env.*
!.env.example

# editor / OS
.vscode/
!.vscode/settings.json.example
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# Electron
.electron/
electron-builder.yml.local

# misc cache
.cache/
.parcel-cache/
.turbo/
.next/
