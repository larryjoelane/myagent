# Copy this file to `.env` and fill in your values. `.env` is loaded
# automatically at app startup (electron/main.js) via dotenv. Never
# commit `.env` itself.

# Ollama Cloud worker credentials. Get a key at https://ollama.com.
OLLAMA_API_KEY=

# Default model for the Ollama Cloud worker. If a spawn-time picker is
# shown and the user hasn't changed it, this is what they'll get.
# Defaults to devstral-small-2:24b-cloud — Mistral's agentic coding
# model, "Low Usage" tier on Ollama Cloud (free-tier safe), reliable
# with OpenAI-format tool calls.
#
# Some models in the dropdown (glm-5.1:cloud, kimi-k2:1t-cloud,
# qwen3-coder-next:cloud, qwen3-coder:480b-cloud) require a paid
# Ollama subscription and will return HTTP 403 without it.
# OLLAMA_MODEL=devstral-small-2:24b-cloud

# Comma-separated list of models offered in the spawn-time dropdown.
# Defaults (when unset):
#   ministral-3:3b-cloud,gpt-oss:20b-cloud,gpt-oss:120b-cloud,
#   devstral-small-2:24b-cloud,qwen3-coder-next:cloud,
#   qwen3-coder:480b-cloud,kimi-k2:1t-cloud,glm-4.6:cloud,glm-5.1:cloud
#
# Coder-tuned options:
#   devstral-small-2:24b-cloud — Mistral's agentic coding model, ~24B,
#     "Low Usage" tier (free-tier safe). Best small coder on cloud.
#   qwen3-coder-next:cloud — newer Qwen coder, "High Usage" (likely
#     requires paid subscription).
#   qwen3-coder:480b-cloud — frontier coder, paid.
# OLLAMA_MODELS=ministral-3:3b-cloud,gpt-oss:20b-cloud,gpt-oss:120b-cloud,devstral-small-2:24b-cloud,qwen3-coder-next:cloud,qwen3-coder:480b-cloud,kimi-k2:1t-cloud,glm-4.6:cloud,glm-5.1:cloud

# Optional: override the host. Defaults to https://ollama.com for the
# cloud worker; the local OllamaRunner still defaults to 127.0.0.1:11434.
# OLLAMA_HOST=https://ollama.com

# ---------------------------------------------------------------------------
# OpenRouter worker credentials. Get a key at https://openrouter.ai/keys.
# OpenRouter is an OpenAI-compatible gateway to many model providers; the
# worker rides the same OpenAICompatibleDriver as Ollama Cloud.
OPENROUTER_API_KEY=

# Default model for the OpenRouter worker. Model ids are `vendor/model`
# slugs. Defaults to openai/gpt-5-nano.
# OPENROUTER_MODEL=openai/gpt-5-nano

# Comma-separated list of models offered in the spawn-time dropdown.
# Defaults to openai/gpt-5-nano,openai/gpt-4o-mini when unset. Set this to
# change the options, e.g.:
# OPENROUTER_MODELS=openai/gpt-5-nano,openai/gpt-4o-mini,anthropic/claude-3.7-sonnet

# Optional: override the host. Defaults to https://openrouter.ai/api/v1.
# OPENROUTER_HOST=https://openrouter.ai/api/v1

# Optional: attribution headers OpenRouter shows in your dashboard.
# OPENROUTER_REFERER=https://github.com/larryjoelane/MyAgent
# OPENROUTER_TITLE=MyAgent
