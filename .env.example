# Copy this file to `.env` and fill in your values. `.env` is loaded
# automatically at app startup (electron/main.js) via dotenv. Never
# commit `.env` itself.

# Ollama Cloud worker credentials. Get a key at https://ollama.com.
OLLAMA_API_KEY=

# Default model for the Ollama Cloud worker. If a spawn-time picker is
# shown and the user hasn't changed it, this is what they'll get.
# Defaults to gpt-oss:120b-cloud — works on every Ollama Cloud tier.
#
# Some models in the dropdown (glm-5.1:cloud, kimi-k2:1t-cloud) require
# a paid Ollama subscription and will return HTTP 403 without it.
# OLLAMA_MODEL=gpt-oss:120b-cloud

# Comma-separated list of models offered in the spawn-time dropdown.
# Defaults (when unset):
#   gpt-oss:20b-cloud,gpt-oss:120b-cloud,qwen3-coder:480b-cloud,
#   kimi-k2:1t-cloud,glm-4.6:cloud,glm-5.1:cloud,ibm/granite-docling
#
# Note: ibm/granite-docling is LOCAL-ONLY on Ollama (no -cloud tag).
# Selecting it for an Ollama Cloud worker will fail with "model not
# found" until a separate local-Ollama worker kind is added.
# OLLAMA_MODELS=gpt-oss:20b-cloud,gpt-oss:120b-cloud,qwen3-coder:480b-cloud,kimi-k2:1t-cloud,glm-4.6:cloud,glm-5.1:cloud,ibm/granite-docling

# Optional: override the host. Defaults to https://ollama.com for the
# cloud worker; the local OllamaRunner still defaults to 127.0.0.1:11434.
# OLLAMA_HOST=https://ollama.com
